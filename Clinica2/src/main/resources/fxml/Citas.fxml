<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.clinica.controller.CitasController">
    <top>
        <Label style="-fx-font-size: 22px; -fx-padding: 20;" text="📅 Gestión de Citas" />
    </top>
    <center>
        <VBox fx:id="vboxContenido" alignment="CENTER" spacing="30.0">
            <children>
                <Label fx:id="lblMensaje" style="-fx-font-size: 18px; -fx-text-fill: #e74c3c;" text="En Desarrollo" wrapText="true" />
            </children>
            <padding>
                <Insets top="100.0" />
            </padding>
        </VBox>
    </center>
</BorderPane>