<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.clinica.controller.MainController">
    <top>
        <VBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label style="-fx-font-size: 24px; -fx-text-fill: #2c3e50;" text="🏥 Clínica San Mateo" />
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;" text="Dashboard Principal" />
                    </children>
                    <HBox.margin>
                        <Insets left="20.0" />
                    </HBox.margin>
                </HBox>
            </children>
        </VBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="40.0">
            <children>
                <Label style="-fx-font-size: 20px;" text="Selecciona una opción:" />
                <HBox alignment="CENTER" spacing="30.0">
                    <children>
                        <VBox spacing="15.0">
                            <children>
                                <Button fx:id="btnClientes" onAction="#mostrarClientes" styleClass="nav-button" text="👥 Clientes">
                                    <graphic>
                                        <Label style="-fx-font-size: 48px;" text="👥" />
                                    </graphic>
                                </Button>
                                <Label text="Gestión de Clientes" />
                            </children>
                        </VBox>
                        <VBox spacing="15.0">
                            <children>
                                <Button fx:id="btnCitas" onAction="#mostrarCitas" styleClass="nav-button" text="📅 Citas">
                                    <graphic>
                                        <Label style="-fx-font-size: 48px;" text="📅" />
                                    </graphic>
                                </Button>
                                <Label text="Gestión de Citas" />
                            </children>
                        </VBox>
                        <VBox spacing="15.0">
                            <children>
                                <Button fx:id="btnMedicos" onAction="#mostrarMedicos" styleClass="nav-button" text="👨‍⚕️ Médicos">
                                    <graphic>
                                        <Label style="-fx-font-size: 48px;" text="👨‍⚕️" />
                                    </graphic>
                                </Button>
                                <Label text="Gestión de Médicos" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets top="50.0" right="50.0" bottom="50.0" left="50.0" />
            </padding>
        </VBox>
    </center>
</BorderPane>